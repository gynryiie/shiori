{
  "manifest_version": 3,
  "name": "Shiori",
  "version": "1.3.0",
  "description": "Caches gallery images locally for offline reading. 栞",
  "permissions": [
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://*.nhentai.net/*",
    "https://nhentai.net/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://nhentai.net/*",
        "https://*.nhentai.net/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "pages/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "pages/options/options.html",
  "web_accessible_resources": [
    {
      "resources": [
        "pages/library/library.html",
        "pages/library/library.js",
        "pages/reader/reader.html",
        "pages/reader/reader.js",
        "pages/options/options.html",
        "pages/options/options.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}